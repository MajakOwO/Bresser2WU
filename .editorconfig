# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
end_of_line = lf
insert_final_newline = true
charset = utf-8

# C++ files
[*.{cpp,h,hpp,c}]
indent_style = space
indent_size = 4
max_line_length = 100

# Arduino sketches
[*.ino]
indent_style = space
indent_size = 4

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
trim_trailing_whitespace = false
indent_style = space
indent_size = 2

# Python files
[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

# Makefile
[Makefile]
indent_style = tab

# Configuration files
[{platformio.ini,.gitignore,.gitattributes}]
indent_style = space
indent_size = 2
